# Server environment variables
PORT=1234

# JDoodle Compiler API credentials (get from https://www.jdoodle.com/compiler-api)
# Free tier: 200 credits/day, no card required.
JDOODLE_CLIENT_ID=your_client_id_here
JDOODLE_CLIENT_SECRET=your_client_secret_here

# Client WebSocket URL (for production deployment)
# VITE_WS_URL=wss://your-domain.com
